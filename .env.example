# ── Missing attendance-point reminder workflow ──────────────────
# None of these need to be set for the feature to work — every value below
# already has a working hardcoded default in services/missingPoints.js
# (no Azure Portal access to set App Settings). Only set one of these if you
# specifically want to override its default.

# Base URL used to build the links sent in emails (no trailing slash)
# Default: https://pointeuse-back.azurewebsites.net
PUBLIC_BASE_URL=

# SMTP relay used to send reminder/approval emails
SMTP_HOST=avocarbon-com.mail.protection.outlook.com
SMTP_PORT=25
SMTP_SECURE=false
# "none" for anonymous internal relay (e.g. mail.protection.outlook.com), "basic" otherwise
SMTP_AUTH_MODE=none
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=Administration STS
MAIL_FROM_ADDRESS=administration.STS@avocarbon.com

# Notified once a responsable1 approves a correction
FETHI_NOTIFICATION_EMAIL=fethi.chaouachi@avocarbon.com

# Shared secret required in the "x-automation-key" header to call
# POST /api/missing-points/run. Must be set for that endpoint to work at all.
# In production this is set automatically during deploy from the GitHub
# Actions repo secret MISSING_POINTS_API_KEY (see .github/workflows) —
# add it under GitHub repo Settings > Secrets and variables > Actions.
MISSING_POINTS_API_KEY=

# Optional: override the daily cron schedule (default: Mon-Fri 07:00 Africa/Tunis)
MISSING_POINTS_CRON=0 7 * * 1-5

# Optional safety valve for initial rollout: when set, ALL missing-point
# emails (employee/responsable/Fethi) are redirected to this single address
# instead of real staff, so the flow can be validated against production
# data without emailing real employees. Remove once confident.
MISSING_POINTS_TEST_OVERRIDE_EMAIL=

# Always CC this address on every missing-point email (employee reminder,
# responsable review, Fethi notification), in addition to the real
# recipients — for ongoing oversight of the whole loop.
# Default: rami.mejri@avocarbon.com
MISSING_POINTS_AUDIT_CC=

# ── Leave-balance accrual (rh_application.public.leave_balances) ─
# Writes into the PRE-EXISTING leave_balances table in the rh_application
# database (employee_id, balance, updated_at) — not a table owned by this
# codebase. Updated automatically by a nightly cron. GET /api/leave-balance
# [/:employeeId] are read-only and unauthenticated, matching /api/report's
# existing security posture.
#
# Shared secret required in the "x-automation-key" header to call
# POST /api/leave-balance/resync — the manual rewind used when attendance
# data arrives AFTER the cron already advanced past that window (e.g. the
# ZKTeco device was down and got backfilled later). Pick a long random
# value (e.g. `openssl rand -hex 32`) — do NOT reuse MISSING_POINTS_API_KEY.
# In production this is set automatically during deploy from the GitHub
# Actions repo secret LEAVE_BALANCE_API_KEY.
LEAVE_BALANCE_API_KEY=

# Optional: override the daily cron schedule (default: every day at 02:00 Africa/Tunis)
LEAVE_BALANCE_CRON=0 2 * * *

# ── Remote-work attendance emails ────────────────────────────────
# On any date marked remote (POST /api/remote-days), every active employee
# gets an arrival email in the morning and a departure email in the evening,
# each with a one-click confirmation link that stamps the current server
# time into attendance_daily — used instead of the ZKTeco machine ingestion
# on days nobody is physically in the office.
#
# NOTE: unlike /api/missing-points and /api/leave-balance, these admin
# endpoints (POST/DELETE /api/remote-days, POST /api/remote-attendance/send)
# are intentionally NOT protected by an x-automation-key — by explicit
# choice, at the cost of being callable by anyone who knows the URL.

# Optional: override the arrival/departure cron schedules
# (default: 07:30 / 16:30 Mon-Fri Africa/Tunis). Both are no-ops on any day
# not marked remote, so they're safe to leave running permanently.
REMOTE_ATTENDANCE_ARRIVAL_CRON=30 7 * * 1-5
REMOTE_ATTENDANCE_DEPARTURE_CRON=30 16 * * 1-5

# Uids never emailed (comma-separated). Default: 1 (mirrors
# MISSING_POINTS_EXCLUDED_UIDS — same employee who doesn't badge normally).
REMOTE_ATTENDANCE_EXCLUDED_UIDS=1

# Optional safety valve for initial rollout: when set, ALL remote-attendance
# emails are redirected to this single address instead of real staff.
# Remove once confident.
REMOTE_ATTENDANCE_TEST_OVERRIDE_EMAIL=

# Always CC this address on every remote-attendance email, in addition to
# the real recipient. Default: rami.mejri@avocarbon.com
REMOTE_ATTENDANCE_AUDIT_CC=

# ── Self-service pointage page (employee matricule + PIN login) ─
# POST/GET /api/self-pointage/me and /punch require a valid session token
# issued by POST /api/self-pointage/login — every other endpoint in this
# API stays unauthenticated by design (see notes above), this is the one
# deliberately-protected slice. No external identity provider is involved;
# sessions are our own HS256 JWTs. POST /api/self-pointage/pin/request
# emails a freshly generated 6-digit code directly (replacing any previous
# one) — there is no separate "set your own PIN" link/step.
#
# Required. Long random secret used to sign/verify self-pointage session
# tokens. Generate with e.g. `openssl rand -hex 32`. Do NOT reuse a secret
# from any other project/app.
SELF_POINTAGE_JWT_SECRET=
#
# Optional: how long a login session stays valid before the employee has
# to log in again. Default: 12 hours.
SELF_POINTAGE_SESSION_TTL_HOURS=12
#
# Optional: failed PIN attempts before an account is temporarily locked.
# Default: 5.
SELF_POINTAGE_MAX_FAILED_ATTEMPTS=5
#
# Optional: lockout duration once the failed-attempts threshold is hit.
# Default: 15 minutes.
SELF_POINTAGE_LOCKOUT_MINUTES=15
